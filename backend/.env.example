# ============================================
# Focused Tab Enforcer - Environment Variables
# ============================================

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/focused_tab_enforcer

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Email (Brevo - https://app.brevo.com → Settings → API Keys)
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM=noreply@focusedtab.com
EMAIL_FROM_NAME=Focused Tab Enforcer

# Extension
# (No API key needed — students connect via Exam ID)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=100
RATE_LIMIT_MAX_EXTENSION=1000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
